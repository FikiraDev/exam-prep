node_modules
.DS_Store
dist
dist-ssr

# Env / secrets (explicit; avoid *.local — too broad)
# Use ** patterns so !**/.env.example reliably un-ignores templates (Git negation quirk with .env*)
**/.env
**/.env.*
!**/.env.example
!**/.env.convex.*
.dev.vars*

# Logs / diagnostics
*.log
pnpm-debug.log*
trace*.json.gz

# Tests / TypeScript cache
coverage/
*.tsbuildinfo
apps/web/test-results/
apps/web/playwright-report/

.nitro
.tanstack
.wrangler
.output
.vinxi
.turbo
__unconfig*
todos.json

# VS Code — ignore workspace junk; allow shared configs
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Agents
.agents

.claude

.fallow/
.husky/_/
