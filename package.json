{
  "name": "exam-prep",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build --log-prefix=task",
    "check": "pnpm run lint && pnpm run test && pnpm run format:check",
    "convex:dev": "node ./scripts/run-with-prefix.mjs [convex] convex dev",
    "deploy:convex": "convex deploy",
    "deploy:web": "pnpm --filter web deploy",
    "dev": "turbo run dev --filter=web --log-prefix=task",
    "fix": "pnpm --filter web lint:fix && pnpm run format",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "turbo run lint lint:root --log-prefix=task",
    "lint:root": "oxlint -c oxlint.config.mjs convex scripts --deny-warnings",
    "preview:web": "pnpm --filter web preview",
    "test": "turbo run test --log-prefix=task"
  },
  "devDependencies": {
    "convex": "^1.32.0",
    "eslint-plugin-tailwindcss": "4.0.0-alpha.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "turbo": "^2.5.6",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
